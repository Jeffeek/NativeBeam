<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Reset any inherited sources (machine config, parent NuGet.config,
         etc.) so the build only ever resolves from nuget.org. -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <!-- Pin every package to nuget.org. Adding a private feed later requires
       an explicit prefix mapping rather than a silent fall-through. -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>

  <config>
    <add key="signatureValidationMode" value="accept" />
  </config>

  <!-- Refuse to consume a package that has been deprecated or has a known
       vulnerability without an explicit override. -->
  <auditSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </auditSources>
</configuration>
